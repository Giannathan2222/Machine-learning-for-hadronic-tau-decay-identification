import uproot
import numpy as np
import awkward as ak
import glob
from tqdm.keras import TqdmCallback

#LOAD FILES

arrays = []

directory = r"filepath"
all_files = glob.glob(directory + "/*.root")

print("Loading ROOT files...")

for f in all_files:
    try:
        print("  Loading:", f)
        tree = uproot.open(f)["mini"]
        arr = tree.arrays([
            "tau_pt", "tau_eta", "tau_phi", "tau_E",
            "tau_charge", "tau_nTracks", "tau_truthMatched",
            "lep_pt", "lep_eta", "lep_phi"
        ], library="ak")
        arrays.append(arr)
    except Exception as e:
        print("Skipping:", f, "because:", e)

print("Concatenating arrays...")
arrays = ak.concatenate(arrays, axis=0)

###PREPARE TAU + LEPTON ARRAYS###

tau_pt      = arrays["tau_pt"]
tau_eta     = arrays["tau_eta"]
tau_phi     = arrays["tau_phi"]
tau_E       = arrays["tau_E"]
tau_charge  = arrays["tau_charge"]
tau_nTracks = arrays["tau_nTracks"]
truth       = arrays["tau_truthMatched"]

# Per-event lepton (take first lepton in each event, or None)
lep_pt_evt  = ak.firsts(arrays["lep_pt"])
lep_eta_evt = ak.firsts(arrays["lep_eta"])
lep_phi_evt = ak.firsts(arrays["lep_phi"])

# Broadcast per-event lepton to each tau in that event
lep_pt_b,  _ = ak.broadcast_arrays(lep_pt_evt,  tau_pt)
lep_eta_b, _ = ak.broadcast_arrays(lep_eta_evt, tau_eta)
lep_phi_b, _ = ak.broadcast_arrays(lep_phi_evt, tau_phi)

####Jagged engineered variables####

# ΔR(lep, tau)
deta = tau_eta - lep_eta_b
dphi = np.abs(tau_phi - lep_phi_b)
dphi = ak.where(dphi > np.pi, 2*np.pi - dphi, dphi)
dR = np.sqrt(deta**2 + dphi**2)

# log transforms
log_pt = np.log(tau_pt + 1)
log_E  = np.log(tau_E + 1)

# E/pt
E_over_pt = tau_E / (tau_pt + 1e-6)

#FLATTEN#

pt      = ak.to_numpy(ak.flatten(tau_pt))
eta     = ak.to_numpy(ak.flatten(tau_eta))
phi     = ak.to_numpy(ak.flatten(tau_phi))
E       = ak.to_numpy(ak.flatten(tau_E))
charge  = ak.to_numpy(ak.flatten(tau_charge))
nTracks = ak.to_numpy(ak.flatten(tau_nTracks))
truth_f = ak.to_numpy(ak.flatten(truth))

lep_pt_f   = ak.to_numpy(ak.flatten(lep_pt_b))
lep_eta_f  = ak.to_numpy(ak.flatten(lep_eta_b))
lep_phi_f  = ak.to_numpy(ak.flatten(lep_phi_b))

dR_f        = ak.to_numpy(ak.flatten(dR))
log_pt_f    = ak.to_numpy(ak.flatten(log_pt))
log_E_f     = ak.to_numpy(ak.flatten(log_E))
E_over_pt_f = ak.to_numpy(ak.flatten(E_over_pt))

###Feature Matrix###

X = np.column_stack([
    pt, eta, phi, E, charge, nTracks,
    lep_pt_f, lep_eta_f, lep_phi_f,
    dR_f, log_pt_f, log_E_f, E_over_pt_f
])

y = truth_f.astype(int)

print("X shape:", X.shape)
print("y shape:", y.shape)

#clean data

mask = np.isfinite(X).all(axis=1)
X = X[mask]
y = y[mask]

#Train/test split#

from sklearn.model_selection import train_test_split
X_train, X_test, y_train, y_test = train_test_split(
    X, y,
    test_size=0.3,
    random_state=42,
    stratify=y
)

#CLASS WEIGHTS#

from sklearn.utils.class_weight import compute_class_weight

class_weights = compute_class_weight(
    class_weight='balanced',
    classes=np.unique(y_train),
    y=y_train
)
class_weights = dict(enumerate(class_weights))
print("Class weights:", class_weights)

#scaling#

from sklearn.preprocessing import StandardScaler

scaler = StandardScaler()
X_train = scaler.fit_transform(X_train)
X_test = scaler.transform(X_test)

#TRAIN Neural Network#

from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense, Dropout
from tensorflow.keras.callbacks import EarlyStopping
from tensorflow.keras.optimizers import Adam

model = Sequential([
    Dense(64, activation='relu', input_shape=(X.shape[1],)),
    Dropout(0.2),
    Dense(64, activation='relu'),
    Dropout(0.2),
    Dense(32, activation='relu'),
    Dense(1, activation='sigmoid')
])

model.compile(
    optimizer=Adam(learning_rate=0.0005),
    loss='binary_crossentropy',
    metrics=['accuracy']
)

early_stop = EarlyStopping(
    monitor='val_loss',
    patience=10,
    restore_best_weights=True
)

history = model.fit(
    X_train,
    y_train,
    epochs=25,
    batch_size=256,
    validation_split=0.2,
    callbacks=[early_stop, TqdmCallback(verbose=1)],
    class_weight=class_weights
)

#EVALUATE#

loss, accuracy = model.evaluate(X_test, y_test)
print(f"Test accuracy: {accuracy:.3f}")
print(f"Test loss: {loss:.3f}")

tau_prob = model.predict(X_test).flatten()

from sklearn.metrics import roc_curve, auc
fpr, tpr, _ = roc_curve(y_test, tau_prob)
roc_auc = auc(fpr, tpr)

print(f"ROC AUC: {roc_auc:.3f}")

import matplotlib.pyplot as plt
plt.figure()
plt.plot(fpr, tpr, label=f"ROC curve (area = {roc_auc:.3f})")
plt.plot([0, 1], [0, 1], 'k--')
plt.xlabel("False Positive Rate")
plt.ylabel("True Positive Rate")
plt.title("ROC Curve on Monte Carlo Test Set")
plt.legend()
plt.show()

##3D Loss surface##

from mpl_toolkits.mplot3d import Axes3D
import matplotlib.pyplot as plt
import numpy as np
from matplotlib import cm

# Extract losses
train_loss = np.array(history.history['loss'])
val_loss = np.array(history.history['val_loss'])
epochs = np.arange(1, len(train_loss) + 1)

# Create a grid for surface plotting
E, L = np.meshgrid(epochs, [0, 1])  # 0 = train, 1 = val
Z = np.vstack([train_loss, val_loss])

fig = plt.figure(figsize=(12, 8))
ax = fig.add_subplot(111, projection='3d')

# Plot surface
surf = ax.plot_surface(
    E, L, Z,
    cmap=cm.viridis,
    edgecolor='k',
    linewidth=0.5,
    antialiased=True,
    alpha=0.9
)

# Labels
ax.set_xlabel('Epoch', fontsize=12)
ax.set_ylabel('Curve (0 = train, 1 = val)', fontsize=12)
ax.set_zlabel('Loss', fontsize=12)
ax.set_title('3D Loss Surface for Neural Network', fontsize=14)

fig.colorbar(surf, shrink=0.5, aspect=10)
plt.show()


